digraph G {

rankdir=TB;
splines=ortho;
nodesep=0.6;
ranksep=1.0;

graph [
    bgcolor="white"
];

node [
    shape=box
    style="rounded,filled"
    fontname="Arial"
    fontsize=10
];

edge [
    fontname="Arial"
];

subgraph cluster_repo {
    label="GitHub Repository";
    color=lightgrey;

    repo [label="monitoring-stack\nRepository", fillcolor=lightblue];
    tf [label="Terraform\n(vSphere / AWS)", fillcolor=lightyellow];
    ansible [label="Ansible\nProvisioning", fillcolor=lightyellow];
    compose [label="Docker Compose", fillcolor=lightyellow];

    repo -> tf;
    repo -> ansible;
    repo -> compose;
}

subgraph cluster_vm {
    label="Debian 13 - monitoring01";
    color=blue;

    docker [label="Docker Engine", fillcolor=lightcyan];

    grafana [label="Grafana\n:3000", fillcolor=lightgreen];
    prometheus [label="Prometheus\n:9090", fillcolor=lightgreen];
    alertmanager [label="Alertmanager\n:9093", fillcolor=lightgreen];
    blackbox [label="Blackbox Exporter\n:9115", fillcolor=lightgreen];

    docker -> grafana;
    docker -> prometheus;
    docker -> alertmanager;
    docker -> blackbox;
}

tf -> ansible;
ansible -> docker;

subgraph cluster_targets {
    label="Monitored Infrastructure";
    color=darkgreen;

    docker_vm [label="ubuntu-docker\n192.168.2.51\nNode Exporter", fillcolor=lightgrey];

    nextcloud_vm [label="nextcloud\n192.168.2.60\nNode Exporter", fillcolor=lightgrey];

    future [label="Future Nodes\nNode Exporter", fillcolor=white];
}

prometheus -> docker_vm;
prometheus -> nextcloud_vm;
prometheus -> future;

grafana -> prometheus;
prometheus -> alertmanager;
blackbox -> docker_vm;
blackbox -> nextcloud_vm;

}
